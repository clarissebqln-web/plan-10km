      { id: 'w11s4', day: 'Jeu', name: 'Footing activation', detail: '20 min avec 3×2 min à 6\'00/km au milieu', type: 'run', km: 3 },
      { id: 'w11s5', day: 'Ven', name: 'Repos complet', detail: 'Hydratation, sommeil, récup mentale', type: 'rest' },
      { id: 'w11s6', day: 'Sam', name: 'Repos ou 15 min footing', detail: 'Très court si besoin de bouger', type: 'rest' },
      { id: 'w11s7', day: '🏁 Dim 28 juin', name: '10KM — JOUR J', detail: 'Pars à 6\'05/km les 3 premiers km · Accélère à partir du km 6 si tu te sens bien', type: 'race', km: 10 },
    ]
  },
];

function loadProgress() {
  try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || {}; } catch { return {}; }
}

function saveProgress(p) {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(p));
}

function getTypeClass(type) {
  return { run: 'dot-run', tempo: 'dot-tempo', interval: 'dot-interval', gym: 'dot-gym', rest: 'dot-rest', race: 'dot-race' }[type] || 'dot-rest';
}

function getTypeEmoji(type) {
  return { run: '🏃', tempo: '⚡', interval: '🔥', gym: '🏋️', rest: '😴', race: '🏁' }[type] || '•';
}

function detectCurrentWeek() {
  const today = new Date();
  for (let i = 0; i < weeks.length; i++) {
    const w = weeks[i];
    if (w.id === 'w1') {
      const s = new Date('2026-04-15');
      const e = new Date('2026-04-20');
      if (today >= s && today <= e) return i;
    } else {
      // rough check by week num
      const startDay = new Date('2026-04-21');
      startDay.setDate(startDay.getDate() + (i - 1) * 7);
      const endDay = new Date(startDay);
      endDay.setDate(endDay.getDate() + 6);
      if (today >= startDay && today <= endDay) return i;
    }
  }
  return -1;
}

function countdownDays() {
  const today = new Date();
  today.setHours(0,0,0,0);
  const race = new Date(RACE_DATE);
  race.setHours(0,0,0,0);
  return Math.max(0, Math.round((race - today) / 86400000));
}

function render() {
  const progress = loadProgress();
  const container = document.getElementById('weeks-container');
  const currentWeekIdx = detectCurrentWeek();

  let totalSessions = 0;
  let totalDone = 0;
  let totalRuns = 0;
  let totalKm = 0;

  container.innerHTML = '';

  weeks.forEach((week, wIdx) => {
    const weekDiv = document.createElement('div');
    weekDiv.className = 'week-block';

    const isCurrentWeek = wIdx === currentWeekIdx;
    const allDone = week.sessions.every(s => progress[s.id]);

    const badgeClass = week.badge === 'taper' ? 'badge-taper' : week.badge === 'test 8km' ? 'badge-test' : isCurrentWeek ? 'badge-current' : 'badge-volume';
    const badgeLabel = isCurrentWeek && week.badge !== 'taper' ? '← MAINTENANT' : week.badge;

    weekDiv.innerHTML = `
      <div class="week-header ${isCurrentWeek ? 'current' : ''} ${allDone ? 'done-week' : ''}" onclick="toggleWeek('wb-${week.id}', '${week.id}-chev')">
        <div class="week-left">
          <span class="week-num">S${week.num}</span>
          <div>
            <div class="week-title-text">${week.title}</div>
            <div class="week-dates">${week.dates}</div>
          </div>
        </div>
        <div class="week-right">
          <span class="week-badge ${badgeClass}">${badgeLabel}</span>
          <span class="chevron" id="${week.id}-chev">▼</span>
        </div>
      </div>
      <div class="week-body ${isCurrentWeek ? 'open' : ''}" id="wb-${week.id}">
        ${week.sessions.map(s => {
          totalSessions++;
          if (s.km) { totalKm += s.km; }
          if (s.type === 'run' || s.type === 'tempo' || s.type === 'interval' || s.type === 'race') totalRuns++;
          const done = !!progress[s.id];
          if (done) totalDone++;
          return `
          <div class="session-row ${done ? 'completed' : ''}" onclick="toggleSession('${s.id}')">
            <div class="session-type-dot ${getTypeClass(s.type)}"></div>
            <div class="session-content">
              <div class="session-day">${s.day}</div>
              <div class="session-name">${getTypeEmoji(s.type)} ${s.name}</div>
              ${s.detail ? `<div class="session-detail">${s.detail}</div>` : ''}
            </div>
            <div class="session-checkbox">${done ? '✓' : ''}</div>
          </div>`;
        }).join('')}
      </div>
    `;

    container.appendChild(weekDiv);
  });

  // Update header stats
  document.getElementById('countdown').textContent = countdownDays();
  const pct = Math.round((totalDone / totalSessions) * 100);
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('progressText').textContent = `${totalDone} / ${totalSessions} séances`;
  document.getElementById('progressPct').textContent = pct + '%';
  document.getElementById('statDone').textContent = totalDone;
  document.getElementById('statRuns').textContent = totalRuns;
  document.getElementById('statKm').textContent = Math.round(totalKm);
}

function toggleWeek(bodyId, chevId) {
  const body = document.getElementById(bodyId);
  const chev = document.getElementById(chevId);
  const open = body.classList.toggle('open');
  chev.style.transform = open ? 'rotate(180deg)' : '';
}

function toggleSession(sessionId) {
  const progress = loadProgress();
  progress[sessionId] = !progress[sessionId];
  saveProgress(progress);
  render();
}

function resetAll() {
  if (confirm('Réinitialiser toute la progression ?')) {
    localStorage.removeItem(STORAGE_KEY);
    render();
  }
}

render();
</script>

