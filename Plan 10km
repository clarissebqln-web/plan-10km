<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Plan 10km — Clarisse</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d0d0f;
    --surface: #16161a;
    --card: #1e1e24;
    --border: #2a2a35;
    --accent: #e8ff47;
    --accent2: #ff6b47;
    --accent3: #47b8ff;
    --text: #f0f0f5;
    --muted: #7a7a9a;
    --done: #2a3a1a;
    --done-border: #5a8a2a;
  }

- { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘DM Sans’, sans-serif;
min-height: 100vh;
padding-bottom: 40px;
}

header {
background: var(–surface);
border-bottom: 1px solid var(–border);
padding: 24px 20px 20px;
position: sticky;
top: 0;
z-index: 100;
}

.header-top {
display: flex;
justify-content: space-between;
align-items: flex-start;
margin-bottom: 16px;
}

.title-block h1 {
font-family: ‘Syne’, sans-serif;
font-size: 22px;
font-weight: 800;
color: var(–accent);
letter-spacing: -0.5px;
}

.title-block p {
font-size: 12px;
color: var(–muted);
font-family: ‘DM Mono’, monospace;
margin-top: 2px;
}

.race-countdown {
background: var(–accent);
color: #000;
padding: 8px 14px;
border-radius: 8px;
text-align: center;
}

.race-countdown .days {
font-family: ‘Syne’, sans-serif;
font-size: 24px;
font-weight: 800;
line-height: 1;
}

.race-countdown .label {
font-size: 9px;
font-weight: 500;
letter-spacing: 1px;
text-transform: uppercase;
opacity: 0.7;
}

.progress-bar-wrap {
background: var(–border);
border-radius: 4px;
height: 6px;
overflow: hidden;
}

.progress-bar-fill {
height: 100%;
background: linear-gradient(90deg, var(–accent), var(–accent2));
border-radius: 4px;
transition: width 0.5s ease;
}

.progress-label {
display: flex;
justify-content: space-between;
font-size: 11px;
color: var(–muted);
font-family: ‘DM Mono’, monospace;
margin-top: 6px;
}

.stats-row {
display: grid;
grid-template-columns: 1fr 1fr 1fr;
gap: 10px;
padding: 16px 20px;
}

.stat-card {
background: var(–card);
border: 1px solid var(–border);
border-radius: 12px;
padding: 14px 10px;
text-align: center;
}

.stat-card .val {
font-family: ‘Syne’, sans-serif;
font-size: 20px;
font-weight: 800;
}

.stat-card .lbl {
font-size: 10px;
color: var(–muted);
text-transform: uppercase;
letter-spacing: 0.5px;
margin-top: 3px;
}

.section-title {
font-family: ‘Syne’, sans-serif;
font-size: 11px;
font-weight: 700;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–muted);
padding: 0 20px;
margin: 6px 0 10px;
}

.week-block {
margin: 0 12px 12px;
border-radius: 14px;
overflow: hidden;
border: 1px solid var(–border);
background: var(–card);
}

.week-header {
display: flex;
align-items: center;
justify-content: space-between;
padding: 14px 16px;
cursor: pointer;
user-select: none;
-webkit-user-select: none;
}

.week-header.current {
background: rgba(232, 255, 71, 0.06);
border-left: 3px solid var(–accent);
}

.week-header.done-week {
opacity: 0.6;
}

.week-left {
display: flex;
align-items: center;
gap: 12px;
}

.week-num {
font-family: ‘DM Mono’, monospace;
font-size: 11px;
color: var(–muted);
min-width: 28px;
}

.week-title-text {
font-family: ‘Syne’, sans-serif;
font-size: 14px;
font-weight: 700;
}

.week-dates {
font-size: 11px;
color: var(–muted);
font-family: ‘DM Mono’, monospace;
margin-top: 1px;
}

.week-right {
display: flex;
align-items: center;
gap: 10px;
}

.week-badge {
font-size: 10px;
padding: 3px 9px;
border-radius: 20px;
font-weight: 500;
font-family: ‘DM Mono’, monospace;
}

.badge-volume {
background: rgba(71, 184, 255, 0.15);
color: var(–accent3);
}

.badge-taper {
background: rgba(232, 255, 71, 0.15);
color: var(–accent);
}

.badge-current {
background: var(–accent);
color: #000;
font-weight: 700;
}

.badge-test {
background: rgba(255, 107, 71, 0.2);
color: var(–accent2);
}

.chevron {
color: var(–muted);
font-size: 12px;
transition: transform 0.25s;
}

.week-body {
display: none;
border-top: 1px solid var(–border);
}

.week-body.open {
display: block;
}

.session-row {
display: flex;
align-items: flex-start;
gap: 12px;
padding: 12px 16px;
border-bottom: 1px solid var(–border);
cursor: pointer;
transition: background 0.15s;
}

.session-row:last-child {
border-bottom: none;
}

.session-row:active {
background: rgba(255,255,255,0.03);
}

.session-row.completed {
background: var(–done);
}

.session-checkbox {
width: 22px;
height: 22px;
border-radius: 50%;
border: 2px solid var(–border);
flex-shrink: 0;
display: flex;
align-items: center;
justify-content: center;
margin-top: 1px;
transition: all 0.2s;
font-size: 11px;
}

.session-row.completed .session-checkbox {
background: var(–done-border);
border-color: var(–done-border);
color: #fff;
}

.session-content {
flex: 1;
}

.session-day {
font-size: 10px;
font-family: ‘DM Mono’, monospace;
color: var(–muted);
text-transform: uppercase;
letter-spacing: 0.5px;
}

.session-name {
font-size: 14px;
font-weight: 500;
margin: 2px 0;
line-height: 1.3;
}

.session-row.completed .session-name {
text-decoration: line-through;
opacity: 0.6;
}

.session-detail {
font-size: 12px;
color: var(–muted);
line-height: 1.4;
}

.session-type-dot {
width: 8px;
height: 8px;
border-radius: 50%;
flex-shrink: 0;
margin-top: 7px;
}

.dot-run { background: var(–accent); }
.dot-tempo { background: var(–accent2); }
.dot-interval { background: var(–accent3); }
.dot-gym { background: #a47bff; }
.dot-rest { background: var(–muted); }
.dot-race { background: #ff4747; }

.legend {
display: flex;
gap: 14px;
flex-wrap: wrap;
padding: 0 20px;
margin-bottom: 16px;
}

.legend-item {
display: flex;
align-items: center;
gap: 5px;
font-size: 11px;
color: var(–muted);
}

.legend-dot {
width: 7px;
height: 7px;
border-radius: 50%;
}

.tips-block {
margin: 0 12px 20px;
background: var(–card);
border: 1px solid var(–border);
border-radius: 14px;
padding: 16px;
}

.tips-block h3 {
font-family: ‘Syne’, sans-serif;
font-size: 13px;
font-weight: 700;
color: var(–accent);
margin-bottom: 10px;
letter-spacing: 0.5px;
}

.tip-item {
display: flex;
gap: 10px;
margin-bottom: 8px;
font-size: 13px;
line-height: 1.4;
color: var(–text);
}

.tip-item:last-child { margin-bottom: 0; }

.tip-icon { flex-shrink: 0; }

.race-card {
margin: 0 12px 20px;
background: linear-gradient(135deg, #1a1a10, #1e200a);
border: 2px solid var(–accent);
border-radius: 14px;
padding: 20px;
text-align: center;
}

.race-card .race-emoji { font-size: 32px; margin-bottom: 8px; }
.race-card h2 {
font-family: ‘Syne’, sans-serif;
font-size: 20px;
font-weight: 800;
color: var(–accent);
}
.race-card p { font-size: 13px; color: var(–muted); margin-top: 4px; }

.reset-btn {
display: block;
margin: 0 auto 10px;
background: transparent;
border: 1px solid var(–border);
color: var(–muted);
padding: 8px 18px;
border-radius: 20px;
font-size: 11px;
font-family: ‘DM Mono’, monospace;
cursor: pointer;
letter-spacing: 0.5px;
}
</style>

</head>
